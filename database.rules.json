{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "$roomCode.length >= 4 && $roomCode.length <= 8",
        "moves": {
          "$seq": {
            ".validate": "newData.hasChildren(['fromRow','fromCol','toRow','toCol','author','ts']) && newData.child('author').val().matches(/^[wb]$/) && newData.child('fromRow').isNumber() && newData.child('fromCol').isNumber() && newData.child('toRow').isNumber() && newData.child('toCol').isNumber() && !data.exists()"
          }
        },
        "createdAt": {
          ".validate": "(!data.exists() && newData.isNumber()) || data.val() == newData.val()"
        },
        "lastActivity": {
          ".validate": "newData.isNumber()"
        },
        "host": {
          ".validate": "newData.hasChildren(['clientId','online','name'])",
          "name":     { ".validate": "newData.isString() && newData.val().length <= 16" },
          "clientId": { ".validate": "newData.isString() && newData.val().length <= 64" },
          "online":   { ".validate": "newData.isBoolean()" },
          "lastSeen": { ".validate": "newData.isNumber()" },
          "uid":      { ".validate": "newData.isString() && newData.val().length <= 64" },
          "$other":   { ".validate": false }
        },
        "guest": {
          ".validate": "newData.hasChildren(['clientId','online','name'])",
          "name":     { ".validate": "newData.isString() && newData.val().length <= 16" },
          "clientId": { ".validate": "newData.isString() && newData.val().length <= 64" },
          "online":   { ".validate": "newData.isBoolean()" },
          "lastSeen": { ".validate": "newData.isNumber()" },
          "uid":      { ".validate": "newData.isString() && newData.val().length <= 64" },
          "$other":   { ".validate": false }
        },
        "status": { ".validate": "newData.val() == 'waiting' || newData.val() == 'playing' || newData.val() == 'ended'" },
        "resign": { ".validate": "newData.val() == null || newData.val() == 'w' || newData.val() == 'b'" },
        "rematch": {
          "w": { ".validate": "newData.isBoolean()" },
          "b": { ".validate": "newData.isBoolean()" }
        },
        "$other": { ".validate": false }
      }
    }
  }
}
